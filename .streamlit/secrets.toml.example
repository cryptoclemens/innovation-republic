# ============================================================
# Innovation Republic – Streamlit Cloud Secrets
# ============================================================
# Diese Datei NICHT committen. Werte im Streamlit Cloud Dashboard
# unter App Settings → Secrets eintragen.
# ============================================================

# Supabase PostgreSQL-Verbindung
# Zu finden unter: supabase.com → Project → Settings → Database → URI
DATABASE_URL = "postgresql://postgres:[DEIN-PASSWORT]@[DEIN-HOST].supabase.co:5432/postgres"

# Anthropic API Key für Query-Normalisierung (Option C)
ANTHROPIC_API_KEY = "sk-ant-..."

# Optional: Admin-Passwort
ADMIN_PASSWORD = "bitte_aendern"
