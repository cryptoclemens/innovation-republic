# ============================================================
# Innovation Republic – Umgebungsvariablen
# Kopiere diese Datei als .env und fülle die Werte aus
# ============================================================

# --- Datenbankverbindung ---
DATABASE_URL=postgresql://ir_user:ir_password@localhost:5432/innovation_republic

# --- API-Keys für Datenquellen ---

# Dealroom (PRIMÄRQUELLE für DACH-Startups)
# Beantragen unter: https://dealroom.co/api
# Free-Tier verfügbar für Non-Profits und Forschungseinrichtungen
DEALROOM_API_KEY=your_dealroom_api_key_here

# AngelList (Early-Stage-Ergänzung, kostenlos)
# Registrierung unter: https://angel.co/api
ANGELLIST_API_KEY=your_angellist_api_key_here

# Crunchbase (NUR FÜR DEMO – nach Demo auf false setzen!)
# Beantragen unter: https://data.crunchbase.com/docs/crunchbase-basic-getting-started
# ACHTUNG: ToS erlaubt keine dauerhafte Persistenz in eigenen Datenbanken
CRUNCHBASE_API_KEY=your_crunchbase_api_key_here
CRUNCHBASE_ENABLED=true

# --- KI-gestützte Query-Normalisierung (Option C) ---
# Verbessert die Klassifizierungsgenauigkeit signifikant.
# Ohne Key: Fallback auf direktes Embedding (funktioniert, aber ungenauer).
# Kosten: ~$0,00008 pro Anfrage (claude-haiku-4-5) → bei 10.000 Anfragen: ~$0,80
# API-Key erstellen: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Admin-Interface ---
# Sicheres Passwort für das Admin-Panel wählen
ADMIN_PASSWORD=bitte_aendern_vor_produktionseinsatz

# --- Modell-Konfiguration ---
# Unterstützt Deutsch – kein API-Key erforderlich (lokal)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --- Optionale Einstellungen ---
# Maximale Anzahl Startups pro Ingestion-Lauf (0 = unbegrenzt)
MAX_STARTUPS_PER_SOURCE=1000

# Logging-Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
