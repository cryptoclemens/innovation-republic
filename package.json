{
  "name": "innovation-republic-web",
  "version": "0.1.0",
  "description": "Innovation Republic — Website (statische Marketing-Seite, deploy auf Cloudflare Pages)",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:staging": "SITE_URL=https://innovation-republic.eu node build.mjs",
    "build:prod": "SITE_URL=https://innovation-republic.de node build.mjs",
    "dev": "SITE_URL=https://innovation-republic.eu node build.mjs --watch --serve",
    "clean": "rm -rf dist",
    "deploy": "wrangler pages deploy dist"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
